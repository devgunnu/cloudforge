{
  "name": "cloudforge-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/app",
    "dev:app": "npm run dev --workspace=apps/app",
    "build": "npm run build --workspace=apps/app",
    "lint": "npm run lint --workspace=apps/app"
  }
}
