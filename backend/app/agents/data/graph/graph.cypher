MATCH (a {id: "user_respect"}), (b {id: "privacy_control"})
CREATE (a)-[:ENABLES {reason: "We should stop regarding users as metrics to be optimized, and remember that they are humans who deserve respect, dignity, and agency", confidence: 0.85, conflicted: false, source: "ch216_s05"}]->(b);
MATCH (a {id: "gdpr"}), (b {id: "online_advertising"})
CREATE (a)-[:RECOMMENDS {reason: "GDPR has had some effect on the online advertising industry", confidence: 0.8, conflicted: false, source: "ch216_s05"}]->(b);
MATCH (a {id: "weak_enforcement"}), (b {id: "online_advertising"})
CREATE (a)-[:TRADEOFF {reason: "GDPR has been weakly enforced and does not seem to have led to much of a change in culture and practices across the wider tech industry", confidence: 0.8, conflicted: false, source: "ch216_s05"}]->(b);
