  "files": [
    {"name": "providers.tf", "content": "...HCL content..."},
    {"name": "variables.tf", "content": "...HCL content..."},
    {"name": "main.tf", "content": "...HCL content..."},
    {"name": "outputs.tf", "content": "...HCL content..."}
  ]
