{
  "cloud_provider": "aws",
  "project_name": "todo-app",
  "services": [
    {
      "id": "api_gw",
      "service_type": "api_gateway",
      "label": "REST API Gateway",
      "config": {}
    },
    {
      "id": "todo_fn",
      "service_type": "lambda",
      "label": "Todo CRUD Handler",
      "config": {
        "runtime": "python3.12",
        "memory": 256,
        "timeout": 30
      }
    },
    {
      "id": "todos_table",
      "service_type": "dynamodb",
      "label": "Todos DynamoDB Table",
      "config": {
        "partition_key": "userId",
        "sort_key": "todoId",
        "billing_mode": "PAY_PER_REQUEST"
      }
    },
    {
      "id": "frontend",
      "service_type": "amplify",
      "label": "React Frontend (Amplify Hosting)",
      "config": {
        "branch": "main",
        "framework": "react"
      }
    }
  ],
  "connections": [
    {
      "source": "api_gw",
      "target": "todo_fn",
      "relationship": "routes_to"
    },
    {
      "source": "todo_fn",
      "target": "todos_table",
      "relationship": "reads_writes"
    },
    {
      "source": "frontend",
      "target": "api_gw",
      "relationship": "calls"
    }
  ]
}
