APP_NAME=CloudForge API
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
OLLAMA_BASE_URL=http://localhost:11434
QWEN_MODEL=qwen3.5:latest
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=90
ENABLE_WEB_SEARCH=true
MAX_CLARIFICATION_ROUNDS=3
MAX_RESEARCH_ROUNDS=3

# Agent 2 — Architecture Planner
# Use "anthropic" + set ANTHROPIC_API_KEY for Claude; defaults to local Ollama.
ARCH_MODEL_TYPE=ollama
ARCH_MODEL_NAME=llama3.1:8b
# ANTHROPIC_API_KEY=sk-ant-...

# Agent 3 — Terraform / Code Generator (always Ollama)
AGENT3_MODEL=qwen3.5
AGENT3_FAST_MODEL=qwen3.5
